# Aggre configuration
# Copy to .env and adjust as needed

# === Dokploy (set in Dokploy UI, NOT in .env file) ===
# TS_AUTHKEY=tskey-auth-...  (Tailscale reusable auth key)
# POSTGRES_USER=aggre
# POSTGRES_PASSWORD=<strong-password>
# POSTGRES_DB=aggre

# === Local compute (.env on dev machine) ===
# Connection to remote data services via Tailscale
AGGRE_DATABASE_URL=postgresql+psycopg://aggre:<password>@aggre-shen:5432/aggre
AGGRE_BRONZE_BACKEND=s3
AGGRE_BRONZE_S3_ENDPOINT=http://aggre-shen:3900
AGGRE_BRONZE_S3_BUCKET=aggre-bronze
AGGRE_BRONZE_S3_ACCESS_KEY=<garage-key-id>
AGGRE_BRONZE_S3_SECRET_KEY=<garage-secret-key>
AGGRE_BRONZE_S3_REGION=garage

# Hatchet (local server)
HATCHET_CLIENT_TOKEN=<from-hatchet-ui>

# Whisper (local server)
# AGGRE_WHISPER_SERVER_URL=http://host.docker.internal:8090  # set in compose, not .env

# Telegram (optional)
# AGGRE_TELEGRAM_API_ID=
# AGGRE_TELEGRAM_API_HASH=
# AGGRE_TELEGRAM_SESSION=

# Proxy (optional)
# AGGRE_PROXY_API_URL=http://proxy-api:8080

# Jina Reader (optional — fallback for webpage extraction)
# AGGRE_JINA_READER_URL=https://r.jina.ai
